msgid "`DS_WORKER_ADDR`"
msgstr "`DS_WORKER_ADDR`"

#: ../../source/user_guide/feature_guide/kv_pool.md
msgid ""
"Datasystem worker address in `<host>:<port>` format. This must match the "
"local `dscli start --worker_address` value."
msgstr "数据系统工作节点地址，格式为 `<主机>:<端口>`。此值必须与本地 `dscli start --worker_address` 的值匹配。"

