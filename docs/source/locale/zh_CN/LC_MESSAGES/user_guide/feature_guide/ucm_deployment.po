msgstr "无 UCM 的基线，HBM 前缀缓存禁用（完全重新计算）"

#: ../../source/user_guide/feature_guide/ucm_deployment.md
msgid "**HBM PC**"
msgstr "**HBM PC**"

#: ../../source/user_guide/feature_guide/ucm_deployment.md
msgid "Without UCM, HBM prefix cache enabled"
msgstr "无 UCM，HBM 前缀缓存启用"

#: ../../source/user_guide/feature_guide/ucm_deployment.md
msgid "**UCM PC**"
msgstr "**UCM PC**"

