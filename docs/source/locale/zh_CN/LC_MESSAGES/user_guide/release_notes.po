#: ../../source/user_guide/release_notes.md:484
msgid "CANN is upgraded to 8.5.0"
msgstr "CANN 已升级至 8.5.0。"

#: ../../source/user_guide/release_notes.md:485
msgid ""
"torch-npu is upgraded to 2.8.0.post1. Please note that the post version "
