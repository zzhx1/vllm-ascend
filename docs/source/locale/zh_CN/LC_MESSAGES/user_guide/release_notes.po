msgstr ""
"GLM4.6 支持全图模式下的 mtp [#5460](https://github.com/vllm-project/vllm-"
"ascend/pull/5460)"

#: ../../source/user_guide/release_notes.md:477
msgid ""
"Flashcomm2 now works with oshard generalized feature "
"[#4723](https://github.com/vllm-project/vllm-ascend/pull/4723)"
msgstr ""
"Flashcomm2 现已支持 oshard 通用化特性 [#4723](https://github.com/vllm-project"
