msgid "`linux-aarch64-310p-*`"
msgstr "`linux-aarch64-310p-*`"

#: ../../source/developer_guide/contribution/e2e_ci_test.md:55
msgid "All other paths"
msgstr "所有其他路径"

#: ../../source/developer_guide/contribution/e2e_ci_test.md:55
